## pub-star-classifier sample env
## - 복사해서 .env로 저장하고 값을 채우세요.
## - .env는 git에 커밋하지 않는 것을 권장합니다.

# GitHub username (필수)
PSC_USER_ID=

# GitHub Token (선택: rate limit 완화)
# - Fine-grained 또는 classic PAT
# - 공개 저장소 조회만이면 최소 권한으로 운영 권장
PSC_GITHUB_TOKEN=

# 기본 출력 디렉토리 (선택)
# PSC_OUT_DIR=./output

# GitHub 요약용 Gemini API Key
GEMINI_API_KEY=AIzaSy...본인의_제미나이_API_키를_입력하세요
